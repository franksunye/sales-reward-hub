# 环境配置模板文件
# 复制此文件为 .env 并填入真实的配置信息
# 注意：.env 文件包含敏感信息，不应提交到版本控制系统

# 环境设置
ENVIRONMENT=development

# ===== Metabase 配置 =====
METABASE_URL=http://112.126.77.6:3000
API_URL_BJ_SIGN_BROADCAST=http://112.126.77.6:3000/question/2003
API_URL_PENDING_ORDERS_REMINDER=http://112.126.77.6:3000/api/card/1712/query
API_URL_PROJECT_SETTLEMENT_SMARTSHEET=http://112.126.77.6:3000/api/card/2015/query

# ===== 数据库源配置 =====
# local: 使用本地 SQLite（默认）
# cloud: 使用 Turso（需配置 TURSO_DB_URL/TURSO_AUTH_TOKEN）
DB_SOURCE=local
LOCAL_DB_PATH=performance_data.db
TURSO_DB_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ===== 认证凭据 =====
# Metabase认证（高敏感度信息）
METABASE_USERNAME=your_username@example.com
METABASE_PASSWORD=your_password

# ===== Webhook URLs =====
# 企业微信Webhook（高敏感度信息）
# 默认群：SLA 日报、待预约工单（未命中 ORG_MAP 时）等均使用此地址
WECOM_WEBHOOK_DEFAULT=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=4fbae71d-8d83-479f-a2db-7690eeb37a5c
WECOM_WEBHOOK_SIGN_BROADCAST_DEFAULT=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_sign_broadcast_webhook_key
WECOM_PROJECT_SETTLEMENT_SMARTSHEET_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/wedoc/smartsheet/webhook?key=your_project_settlement_smartsheet_webhook_key
WECOM_WEBHOOK_PENDING_ORDERS_FORCE_URL=
WECOM_WEBHOOK_PENDING_ORDERS_ORG_MAP={"北京经常亮工程技术有限公司":"https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_provider_specific_webhook_key"}
WECOM_WEBHOOK_CONTACT_TIMEOUT=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_timeout_webhook_key

# ===== 联系人信息 =====
# 联系电话（高敏感度信息）
CONTACT_PHONE_NUMBER=your_phone_number
